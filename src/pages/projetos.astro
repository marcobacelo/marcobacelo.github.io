---
import Layout from "../layouts/Layout.astro";
import { projects } from "../config/site";
---

<Layout
  title="Projetos"
  description="Casos e produtos desenvolvidos pela Royal Software Engineering."
>
  <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6 sm:py-20 compact-vertical-section xl:max-w-7xl">
    <h1 class="text-3xl font-bold text-white sm:text-4xl">Projetos</h1>
    <p class="mt-4 max-w-2xl text-slate-400">
      Alguns dos produtos e soluções que desenvolvemos e operamos.
    </p>
    <div class="mt-12 space-y-6">
      {
        projects.map((p) => (
          <article class="rounded-2xl border border-slate-800 bg-royal-900/50 p-5 transition hover:border-slate-700 sm:p-6 lg:p-8">
            <div class="flex flex-col gap-4 sm:flex-row sm:flex-wrap sm:items-start sm:justify-between">
              <div>
                <h2 class="text-xl font-semibold text-white">{p.name}</h2>
                <p class="mt-2 max-w-2xl text-sm leading-relaxed text-slate-400">{p.description}</p>
                <ul class="mt-4 flex flex-wrap gap-2">
                  {p.tags.map((tag) => (
                    <li class="rounded-full bg-royal-800 px-3 py-1 text-xs font-medium text-slate-300">
                      {tag}
                    </li>
                  ))}
                </ul>
              </div>
              {p.url ? (
                <a
                  href={p.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex min-h-11 w-full shrink-0 items-center justify-center rounded-lg border border-slate-600 px-4 py-2 text-sm font-medium text-slate-200 hover:border-royal-accent hover:text-white sm:w-auto"
                >
                  {p.linkLabel ?? "Acessar em produção"}
                </a>
              ) : null}
            </div>
          </article>
        ))
      }
    </div>
  </section>
</Layout>
