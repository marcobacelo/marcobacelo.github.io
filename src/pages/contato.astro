---
import Layout from "../layouts/Layout.astro";
import ContactForm from "../components/react/ContactForm";
import { site } from "../config/site";
---

<Layout title="Contato" description="Entre em contato com a Royal Software Engineering.">
  <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6 sm:py-20 compact-vertical-section xl:max-w-7xl">
    <div class="grid gap-12 md:grid-cols-2">
      <div>
        <h1 class="text-3xl font-bold text-white sm:text-4xl">Contato</h1>
        <p class="mt-4 text-slate-400">
          Conte-nos sobre seu projeto, prazo ou desafio técnico. Responderemos por e-mail o mais
          breve possível.
        </p>
        <dl class="mt-8 space-y-4 text-sm">
          <div>
            <dt class="font-medium text-slate-500">E-mail</dt>
            <dd>
              <a href={`mailto:${site.email}`} class="break-anywhere text-royal-accent-light hover:underline">
                {site.email}
              </a>
            </dd>
          </div>
          <div>
            <dt class="font-medium text-slate-500">GitHub</dt>
            <dd>
              <a
                href={site.github}
                target="_blank"
                rel="noopener noreferrer"
                class="text-slate-300 hover:text-white"
              >
                {site.github.replace("https://github.com/", "")}
              </a>
            </dd>
          </div>
        </dl>
      </div>
      <div class="rounded-2xl border border-slate-800 bg-royal-900/40 p-5 sm:p-8">
        <ContactForm client:load />
      </div>
    </div>
  </section>
</Layout>
