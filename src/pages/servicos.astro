---
import Layout from "../layouts/Layout.astro";
import { services } from "../config/site";
---

<Layout
  title="Serviços"
  description="Desenvolvimento de produto, nuvem, DevOps e consultoria técnica."
>
  <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6 sm:py-20 compact-vertical-section xl:max-w-7xl">
    <h1 class="text-3xl font-bold text-white sm:text-4xl">Serviços</h1>
    <p class="mt-4 max-w-2xl text-slate-400">
      Atuamos desde o MVP até ambientes de produção, sempre com entregas concretas.
    </p>
    <div class="mt-12 grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
      {
        services.map((s, i) => (
          <article class="relative rounded-2xl border border-slate-800 bg-gradient-to-b from-royal-900/80 to-royal-950 p-5 sm:p-6 lg:p-8">
            <span class="text-4xl font-bold text-slate-800" aria-hidden="true">
              {String(i + 1).padStart(2, "0")}
            </span>
            <h2 class="mt-4 text-xl font-semibold text-white">{s.title}</h2>
            <p class="mt-3 text-sm leading-relaxed text-slate-400">{s.description}</p>
          </article>
        ))
      }
    </div>
    <div class="mt-12 rounded-xl border border-slate-800 bg-royal-900/40 p-5 sm:p-8">
      <h2 class="text-lg font-semibold text-white">Tecnologias usuais</h2>
      <p class="mt-2 text-sm text-slate-400">
        TypeScript, NestJS, Next.js, Astro, AWS (EC2, DynamoDB, S3, ECR), Terraform, GitHub Actions
        e Docker.
      </p>
    </div>
  </section>
</Layout>
